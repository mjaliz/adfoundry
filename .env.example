OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_TIMEOUT_SECONDS=45
ADFOUNDRY_RUN_MODE=live
ADFOUNDRY_OUTPUT_ROOT=outputs
ADFOUNDRY_BROWSER_TIMEOUT_MS=12000
ADFOUNDRY_BROWSER_HEADLESS=true
ADFOUNDRY_BROWSER_SLOW_MO_MS=0
# Optional for local, non-Docker runs with a manually downloaded Chromium.
# Docker images install Chromium during the server image build.
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/absolute/path/to/chromium
ADFOUNDRY_ENABLE_IMAGE_GENERATION=true
ADFOUNDRY_IMAGE_SIZE=1536x1024
ADFOUNDRY_IMAGE_QUALITY=medium
ADFOUNDRY_IMAGE_FORMAT=png
ADFOUNDRY_IMAGE_MAX_REFERENCES=3
ADFOUNDRY_HTML_MAX_ATTEMPTS=3
ADFOUNDRY_HTML_MIN_SCORE=85
ADFOUNDRY_HTML_REQUIRE_LIVE_QA=true
ADFOUNDRY_LOG_LEVEL=INFO
ADFOUNDRY_WEB_PORT=80
